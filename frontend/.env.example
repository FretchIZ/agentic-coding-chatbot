# Frontend environment variables
# Copy to .env.local and fill in your values

# Backend API URL (production: your Render URL)
VITE_API_URL=https://your-backend-name.onrender.com/api

# Backend WebSocket URL (production: your Render URL with wss://)
VITE_WS_URL=wss://your-backend-name.onrender.com/api/ws/chat