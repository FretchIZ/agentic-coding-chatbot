generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  role      Role     @default(USER)
  projects  Project[]
  sessions  Session[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  files       File[]
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model File {
  id        String   @id @default(cuid())
  path      String
  content   String
  language  String?
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([projectId, path])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  type        TaskType
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentRuns   AgentRun[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskType {
  CODE
  REVIEW
  TEST
  SEARCH
  PLAN
  RESEARCH
}

model AgentRun {
  id         String   @id @default(cuid())
  agentId    String
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  status     RunStatus @default(RUNNING)
  input      String
  output     String?
  error      String?
  startedAt  DateTime @default(now())
  completedAt DateTime?
  logs       Log[]
}

enum RunStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Log {
  id        String   @id @default(cuid())
  level     LogLevel
  message   String
  source    String?
  agentRunId String?
  agentRun  AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

model Memory {
  id        String   @id @default(cuid())
  key       String
  value     String
  projectId String?
  userId    String?
  type      String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([key, projectId])
}

model Document {
  id        String   @id @default(cuid())
  title     String
  content   String
  metadata  Json?
  projectId String?
  embedding Vector?  @db.vector(1536)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
