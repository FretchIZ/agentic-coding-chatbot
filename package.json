{
  "name": "codeagent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build --filter=web",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "npm run db:generate -w packages/database",
    "db:push": "npm run db:push -w packages/database",
    "db:migrate": "npm run db:migrate -w packages/database",
    "db:studio": "npm run db:studio -w packages/database"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "workspaces": ["apps/*", "packages/*"],
  "engines": {
    "node": ">=18.0.0"
  }
}
