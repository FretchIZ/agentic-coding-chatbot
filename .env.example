# Database
DATABASE_URL="postgresql://user:password@localhost:5432/learning-platform"
VECTOR_DATABASE_URL="postgresql://user:password@localhost:5432/vector-db"
REDIS_URL="redis://localhost:6379"

# AI Providers
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-..."
VERCEL_AI_API_KEY="..."

# Authentication
CLERK_SECRET_KEY="..."
CLERK_PUBLISHABLE_KEY="..."
NEXTAUTH_SECRET="..."
NEXTAUTH_URL="http://localhost:3000"

# Storage
S3_ENDPOINT="..."
S3_ACCESS_KEY="..."
S3_SECRET_KEY="..."
S3_BUCKET="learning-platform"

# Application
NODE_ENV="development"
PORT=3000
API_PORT=4000
AI_AGENT_PORT=5000

# Feature Flags
ENABLE_AI_AGENTS="true"
ENABLE_VECTOR_SEARCH="true"
ENABLE_RAG="true"
ENABLE_ANALYTICS="true"